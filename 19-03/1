import java.util.*;

class ListNode {
    int val;
    ListNode next;

    ListNode(int x) {
        val = x;
        next = null;
    }
}
// You are using Java-17version 
class Main{
    public static ListNode detectCycle(ListNode head) {
        // Floyds cycle detection algorithm
        // To find the cycle in linkedlist
        ListNode slow = head;
        ListNode fast = head;
        while (fast != null && fast.next != null) {
            slow = slow.next;
            fast = fast.next.next;
            if (slow == fast) {
                slow = head;
                if (slow != fast) {
                    while (slow.next != fast.next) {
                        slow = slow.next;
                        fast = fast.next;
                    }
                    return slow.next;
                }
                else {
                    while (fast.next != slow) {
                        fast = fast.next;
                    }
                    return slow;
                }
            }
        }
        
        // Find startNode
        // slow = head;
        
        return null;
    }
 public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int n = sc.nextInt();

        if (n == 0) {
            System.out.println(-1);
            return;
        }

        int[] arr = new int[n];
        for (int i = 0; i < n; i++)
            arr[i] = sc.nextInt();

        int pos = sc.nextInt();

        ListNode[] nodes = new ListNode[n];

        for (int i = 0; i < n; i++)
            nodes[i] = new ListNode(arr[i]);

        for (int i = 0 ; i < n - 1; i++)
            nodes[i].next = nodes[i + 1];

        if (pos != -1)
            nodes[n - 1].next = nodes[pos];

        ListNode result = detectCycle(nodes[0]);

        if (result != null)
            System.out.println(result.val);
        else
            System.out.println(-1);
    }
}



